{
  "name": "html360",
  "version": "2.4.0",
  "description": "CLI tool to create standalone 360° panoramas in a single HTML file.",
  "keywords": [
    "panorama",
    "360",
    "pannellum",
    "html-app",
    "cli",
    "webp",
    "base64"
  ],
  "homepage": "https://github.com/d-hand/html360#readme",
  "bugs": {
    "url": "https://github.com/d-hand/html360/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d-hand/html360.git"
  },
  "license": "MIT",
  "author": "d_hand",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "html360": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "_base": "tsc && node ./scripts/build.js",
    "build": "npm run _base -- prod",
    "dev": "npm run _base"
  },
  "dependencies": {
    "ansi-colors": "4.1.3",
    "base64-stream": "1.0.0",
    "cli-progress": "3.12.0",
    "commander": "14.0.3",
    "p-limit": "7.3.0",
    "pannellum": "2.5.7",
    "sharp": "0.34.5",
    "windows-shortcuts": "0.1.6"
  },
  "devDependencies": {
    "@types/base64-stream": "1.0.5",
    "@types/cli-progress": "3.11.6",
    "esbuild": "0.27.3",
    "png-to-ico": "3.0.1",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
